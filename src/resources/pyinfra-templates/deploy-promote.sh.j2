######
# 1. # Tear down the original application
######

# Stop, disable, and delete systemd units if present
{%- for unit in vade.app.systemd_units %}
if [ -f "{{ unit.installed_path }}" ]; then
  systemctl is-active --quiet "{{ vade.app.name }}.service" && systemctl stop "{{ vade.app.name }}.service"
  systemctl disable "{{ vade.app.name }}.service"
  rm "{{ unit.installed_path }}"
  systemctl daemon-reload
fi
{%- endfor %}

# Downgrade or remove active deployment dir
{% if downgraded_dir is defined %}
if [ -d "{{ vade.app.paths.active_deployment }}" ]; then
  mv "{{ vade.app.paths.active_deployment }}" "{{ downgraded_dir }}"
fi
{% else %}
rm -rf "{{ vade.app.paths.active_deployment }}"
{% endif %}

# Let Caddy know a previously deployed Caddyfile no longer exists
systemctl reload caddy

######
# 2. # Launch the application from the active deployment
######

# Promote source dir
mv -T "{{ src_dir }}" "{{ vade.app.paths.active_deployment }}"

# Install, enable, and start systemd systemd units
{%- for unit in vade.app.systemd_units %}
if [ -f "{{ unit.active_path }}" ]; then
  cp "{{ unit.active_path }}" "{{ unit.installed_path }}"
  chmod 0644 "{{ unit.installed_path }}"
  chown root:root "{{ unit.installed_path }}"
  systemctl daemon-reload
  systemctl enable --now "{{ unit.name }}"
fi
{%- endfor %}

# Let Caddy know a new Caddyfile might exist
systemctl reload caddy
