###
# Sanity checks
###

# The application's username must not collide with a pre-existing, unmanaged user.
if "{{ vade.app.username }}" in host.get_fact(Users) and not host.get_fact(File, path="{{ vade.app.paths.system_users_entry }}"):
    raise DeployError(
        "Your application's name (`{{ vade.app.username }}`) conflicts with an existing user on the "
        "system. Please choose a different one and try again."
    )

###
# Initialize application
###

files.directory(
    name="Ensure vade user directory exists",
    path="{{ vade.app.paths.system_users_entry | dirname }}",
    user="root",
    group="root",
    mode="755",
)

files.file(
    name="Ensure app user is tracked",
    path="{{ vade.app.paths.system_users_entry }}",
    user="root",
    group="root",
    mode="644",
)

server.user(
    name="Ensure app user exists",
    user="{{ vade.app.username }}",
    system=True,
    ensure_home=False,
)

files.directory(
    name="Ensure app directory exists",
    path="{{ vade.app.paths.home }}",
    user="{{ vade.app.username }}",
    group="{{ vade.app.username }}",
    mode="755",
)

files.directory(
    name="Ensure storage directory exists",
    path="{{ vade.app.paths.storage }}",
    user="{{ vade.app.username }}",
    group="{{ vade.app.username }}",
    mode="700",
)

files.file(
    name="Ensure secrets file exists",
    path="{{ vade.app.paths.secrets }}",
    user="root",
    group="root",
    mode="600",
)

files.directory(
    name="Ensure active deployment exists",
    path="{{ vade.app.paths.active_deployment }}",
    user="{{ vade.app.username }}",
    group="{{ vade.app.username }}",
    mode="755",
)
