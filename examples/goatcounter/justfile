prepare-artifacts:
    curl -s https://api.github.com/repos/arp242/goatcounter/releases/latest | grep -o '"tag_name": "[^"]*' | cut -d'"' -f4 | xargs -I {} sh -c 'mkdir -p artifacts && curl -sL "https://github.com/arp242/goatcounter/releases/download/{}/goatcounter-{}-linux-amd64.gz" | gunzip > artifacts/goatcounter'
    chmod +x artifacts/goatcounter
